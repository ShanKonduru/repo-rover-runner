# Legacy combined template.
# Preferred: use repo_rover_runner.github.env or repo_rover_runner.bitbucket.env.

# Remote repository URL (GitHub or Bitbucket).
# Example SSH: git@github.com:your-org/your-repo.git
# Example HTTPS: https://github.com/your-org/your-repo.git
# Example Bitbucket HTTPS: https://bitbucket.org/your-workspace/your-repo.git
REPO_URL=

# Provider selector for HTTPS auth resolution.
# Values: auto (default), github, bitbucket
REPO_PROVIDER=auto

# Local clone path used by test scripts.
LOCAL_REPO_PATH=./tmp/test-repo

# Branch controls
TARGET_BRANCH=feature/repo-rover-runner-test
BASE_BRANCH=main
REMOTE=origin
BRANCH_TO_LIST=feature/repo-rover-runner-test

# Push controls
TARGET_DIR=integration-tests
COMMIT_MESSAGE=Add dummy file from repo-rover-runner test script

# Optional auth for HTTPS remotes:
# Use one of these approaches:
# 1) Configure git credential manager (recommended)
# 2) Use PAT/App Password in remote URL or credential store
# The CLI does not store tokens by itself.
# If REPO_URL starts with https://, test scripts can use GIT_ASKPASS with:
# - For GitHub: set GITHUB_TOKEN and optionally GIT_USERNAME (default: x-access-token)
# - For Bitbucket: set BITBUCKET_APP_PASSWORD and BITBUCKET_USERNAME (or GIT_USERNAME)
GITHUB_TOKEN=
BITBUCKET_APP_PASSWORD=
BITBUCKET_TOKEN=
GIT_USERNAME=x-access-token
BITBUCKET_USERNAME=
